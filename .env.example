# ── Network ─────────────────────────────────────────────────────────────────
# localnet | devnet | mainnet
NETWORK=localnet

# ── RPC endpoint (used by Next.js app) ──────────────────────────────────────
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8899

# ── Program ID (set automatically by deploy.ts after first deploy) ───────────
NEXT_PUBLIC_PROGRAM_ID=11111111111111111111111111111111

# ── Deploy keypair (path to your Solana CLI identity keypair) ────────────────
# Defaults to ~/.config/solana/id.json if not set
# DEPLOY_KEYPAIR=/path/to/deployer-keypair.json

# ── Program keypair (keeps your program address stable across re-deploys) ────
# Generate once: solana-keygen new -o program-keypair.json
# PROGRAM_KEYPAIR=./program-keypair.json
